{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    
    // CORREÇÃO: Isso permite que o TS reconheça os tipos do @types/express
    "types": ["node"], 
    
    // CORREÇÃO: Essencial para módulos CommonJS (como o Express)
    "esModuleInterop": true, 
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*"] // GARANTA QUE ISSO ESTÁ AQUI
}